# --- App ---
APP_ENV=development
APP_SECRET=change-me-to-long-random-string
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# --- Database ---
POSTGRES_USER=k8cert
POSTGRES_PASSWORD=change-me
POSTGRES_DB=k8certificates
DATABASE_URL=postgresql+asyncpg://k8cert:change-me@postgres:5432/k8certificates

# --- Admin (Basic Auth) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# Comma-separated IPs allowed for /admin (empty = allow all when auth ok)
ADMIN_IP_ALLOWLIST=

# --- Orders ---
RESERVE_TTL_MINUTES=30

# --- Payment: mock | yookassa ---
PAYMENT_PROVIDER=mock

# YooKassa (https://yookassa.ru)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/payment/success
# Пусто = не проверять IP webhook (только для локальной отладки)
YOOKASSA_WEBHOOK_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35,77.75.153.1

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@k8.ru
SMTP_USE_TLS=true

# --- CORS / iframe (Tilda parent) ---
CORS_ORIGINS=http://localhost:3000,https://spa.k8.ru,https://spa2.k8.ru

# Frontend (Docker / build)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SHOW_TEST_BANNER=true
